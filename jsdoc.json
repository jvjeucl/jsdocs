{
  "source": {
    "include": ["src"],
    "includePattern": ".js$"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "tutorials": "./documents",
    "template": "./node_modules/docdash"
  },
  "docdash": {
    "baseUrl": "/jsdocs/"
  },
  "templates": {
    "tabNames": {
      "api": "API",
      "tutorials": "Examples"
    }
  }
}